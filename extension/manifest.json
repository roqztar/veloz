{
  "manifest_version": 3,
  "name": "Veloz Speed Reader",
  "version": "1.0.0",
  "description": "Speed read any text on the web with RSVP (Rapid Serial Visual Presentation)",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "clipboardRead",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      }
    },
    "spritz-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+R"
      },
      "description": "Speed read selected text"
    }
  }
}
